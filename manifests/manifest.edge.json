{
  "$schema": "https://json.schemastore.org/chrome-manifest",
  "manifest_version": 3,
  "name": "OPFS Studio Extension",
  "version": "1.0.0",
  "description": "Following OPFS on the page and edits files via Monaco.",
  "icons": {
    "16": "public/icon128.png",
    "32": "public/icon128.png",
    "48": "public/icon128.png",
    "128": "public/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; img-src 'self' data: blob:; media-src 'self' blob:; frame-src 'self' blob:; connect-src 'self' https:; style-src 'self' 'unsafe-inline'"
  },
  "permissions": [
    "scripting",
    "activeTab",
    "sidePanel",
    "storage"
  ],
  "optional_host_permissions": [
    "<all_urls>"
  ],
  "devtools_page": "src/devtools/devtools.html",
  "background": {
    "service_worker": "src/background/service-entry.ts",
    "type": "module"
  },
  "action": {
    "default_title": "Open OPFS Panel",
    "default_popup": "src/popup/index.html"
  },
  "side_panel": {
    "default_path": "src/panel/index.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/content-entry.ts"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "locales/en/messages.json",
        "locales/ru/messages.json",
        "locales/fr/messages.json",
        "locales/de/messages.json",
        "locales/es/messages.json",
        "locales/zh-CN/messages.json",
        "locales/ja/messages.json"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
