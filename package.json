{
  "name": "opfs-studio-extension",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env TARGET=chrome vite",
    "dev:edge": "cross-env TARGET=edge vite",
    "dev:firefox": "cross-env TARGET=firefox vite",
    "build": "npm run build:chrome",
    "build:chrome": "cross-env TARGET=chrome vite build",
    "build:edge": "cross-env TARGET=edge vite build",
    "build:firefox": "cross-env TARGET=firefox vite build",
    "watch": "npm run watch:chrome",
    "watch:chrome": "cross-env TARGET=chrome vite build --watch --mode development",
    "watch:edge": "cross-env TARGET=edge vite build --watch --mode development",
    "watch:firefox": "cross-env TARGET=firefox vite build --watch --mode development",
    "zip:chrome": "mkdir -p builds && cd dist/chrome && zip -r ../../builds/opfs-studio-chrome.zip .",
    "zip:edge": "mkdir -p builds && cd dist/edge && zip -r ../../builds/opfs-studio-edge.zip .",
    "zip:firefox": "mkdir -p builds && cd dist/firefox && zip -r ../../builds/opfs-studio-firefox.zip .",
    "build:all": "npm run build:chrome && npm run build:edge && npm run build:firefox && npm run zip:chrome && npm run zip:edge && npm run zip:firefox",
    "preview": "vite preview"
  },
  "dependencies": {
    "@inso_web/els-client": "^0.4.2",
    "@inso_web/els-react": "^0.4.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-toolbar": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.1.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "country-flag-icons": "^1.5.19",
    "i18next": "^25.4.2",
    "i18next-browser-languagedetector": "^8.2.0",
    "lucide-react": "^0.540.0",
    "monaco-editor": "0.52.0",
    "next-themes": "^0.4.6",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-i18next": "^15.7.3",
    "react-resizable-panels": "^3.0.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@prettier/plugin-xml": "^3.4.2",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/chrome": "0.0.269",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^24.3.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@vitejs/plugin-react": "^5.0.1",
    "autoprefixer": "^10.4.21",
    "chrome-webstore-upload-cli": "^4.0.0",
    "cross-env": "^10.0.0",
    "dompurify": "^3.4.5",
    "marked": "^18.0.4",
    "papaparse": "^5.5.3",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.12",
    "tw-animate-css": "^1.3.7",
    "typescript": "5.5.4",
    "vite": "5.4.2",
    "vite-plugin-static-copy": "1.0.6"
  }
}
