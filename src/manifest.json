{
  "manifest_version": 3,
  "name": "OPFS Studio Extension",
  "version": "1.0.0",
  "description": "Following OPFS on the page and edits files via Monaco.",
  "icons": {
    "128": "public/icon128.png"
  },
  "permissions": [
    "scripting",
    "activeTab",
    "sidePanel",
    "storage"
  ],
  "devtools_page": "src/devtools/devtools.html",
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Open OPFS Panel"
  },
  "side_panel": {
    "default_path": "src/panel/index.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "assets/content-script.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*",
        "locales/en/common.json",
        "locales/ru/common.json"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}